{
  "name": "wxnovic.github.io",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "npm run build:client && npm run build:server",
    "build:client": "vite build --ssrManifest .vite/ssr-manifest.json --outDir dist/client",
    "build:server": "vite build --ssr src/entry-server.jsx --outDir dist/server",
    "build:server:noExternal": "vite build --config vite.config.noexternal.js --ssr src/entry-server.jsx --outDir dist/server",
    "generate": "cross-env rm -rf dist ; vite build --ssrManifest .vite/ssr-manifest.json --outDir dist/client && npm run build:server && node prerender && node sitemap ; cp -r public/favicon dist/static/favicon",
    "preview": "vite preview",
    "lint": "eslint . --fix --ignore-path .gitignore",
    "deploy": "gh-pages -d dist/static"
  },
  "dependencies": {
    "@reduxjs/toolkit": "^2.5.0",
    "axios": "^1.7.9",
    "bootstrap-icons": "^1.11.3",
    "gh-pages": "^6.2.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-redux": "^9.2.0",
    "uslug": "^1.0.4"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.17.0",
    "eslint-plugin-react": "^7.37.2",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.4.16",
    "fs-extra": "^11.2.0",
    "github-markdown-css": "^5.6.1",
    "globals": "^15.14.0",
    "gray-matter": "^4.0.3",
    "highlight.js": "^11.10.0",
    "markdown-it": "^14.1.0",
    "markdown-it-anchor": "^9.0.1",
    "markdown-it-highlightjs": "^4.1.0",
    "markdown-it-toc-done-right": "^4.2.0",
    "path": "^0.12.7",
    "postcss": "^8.4.49",
    "react-router-dom": "^7.1.1",
    "tailwindcss": "^3.4.17",
    "vite": "^5.4.11",
    "vite-plugin-node-polyfills": "^0.22.0",
    "vite-raw-plugin": "^1.0.2"
  }
}
